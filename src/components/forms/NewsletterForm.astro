---
import Button from "../ui/button/Button.astro";
import { InputField } from "../ui/form";
import Link from "../ui/link/Link.astro";
import { cn } from "../../utils/styles";

interface Props {
  variant?: "inline" | "stack";
  showLegal?: boolean;
  class?: string;
  turnstileClass?: string;
}

const {
  variant = "inline",
  showLegal = false,
  class: cls,
  turnstileClass = "",
} = Astro.props;

const row =
  variant === "inline"
    ? "flex w-full flex-col gap-4 sm:flex-row sm:gap-2"
    : "flex w-full flex-col gap-3";
---

<div class={cls}>
  <form method="POST" action="#" class="space-y-4">
    <div class={row}>
      <InputField
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        maxlength="254"
        autocomplete="email"
        autocapitalize="off"
        spellcheck="false"
      />
      <Button type="submit">Subscribe</Button>
    </div>

    <p class={cn("text-sm text-gray-700 dark:text-gray-300", turnstileClass)}>
      Connect your newsletter provider to make this form live in production.
    </p>

    {showLegal && (
      <div class="flex justify-center">
        <div class="max-w-xl text-center text-sm leading-relaxed text-gray-700 dark:text-gray-300">
          By subscribing, you agree to the
          <Link href="/terms"> Terms &amp; Conditions </Link>
          and
          <Link href="/privacy-policy"> Privacy Policy </Link>
          . You can unsubscribe at any time.
        </div>
      </div>
    )}
  </form>
</div>
