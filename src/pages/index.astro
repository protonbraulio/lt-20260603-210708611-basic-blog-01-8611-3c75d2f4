---
import { getCollection } from "astro:content";
import Container from "../components/layouts/Container.astro";
import ContentGrid from "../components/layouts/sections/ContentGrid.astro";
import FeaturedContent from "../components/layouts/sections/FeaturedContent.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_SETTINGS } from "../site.config";
import { attachMeta } from "../utils/meta";

const allPosts = await getCollection("blog", ({ data }) => data.draft !== true && data.pubDate <= new Date());
const allProjects = await getCollection("projects", ({ data }) => data.draft !== true && data.pubDate <= new Date());

const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const sortedProjects = allProjects.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPosts = sortedPosts.slice(0, 3).map((post) => attachMeta(post));
const latestProjects = sortedProjects
    .slice(0, 2)
    .map((project) => attachMeta(project));

const featured = [...allPosts, ...allProjects]
    .filter((item) => item.data.featured !== undefined)
    .sort((a, b) => (a.data.featured ?? 0) - (b.data.featured ?? 0));

const hasContent =
    featured.length > 0 || latestPosts.length > 0 || latestProjects.length > 0;
---

<BaseLayout
    title="AI-assisted Publishing Guide"
    description="Explain the core principles of AI-assisted publishing for operations managers building repeatable pipelines in Melbourne. Key entities: AI-assisted Publishing."
>
    <Container class="space-y-24 py-12">
        <section class="content-pack-homepage space-y-10">
          <header class="max-w-3xl space-y-4">
            <p class="text-sm font-semibold uppercase tracking-wide text-neutral-600 dark:text-neutral-300">Featured resource</p>
            <h1 class="text-4xl font-bold leading-tight md:text-5xl text-neutral-950 dark:text-neutral-50">AI-assisted Publishing Guide</h1>
            <p class="text-lg leading-8 text-neutral-700 dark:text-neutral-300">Explain the core principles of AI-assisted publishing for operations managers building repeatable pipelines in Melbourne. Key entities: AI-assisted Publishing.</p>
          </header>

          <nav class="space-y-3" aria-label="Table of contents">
            <h2 class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Table of contents</h2>
            <ul class="list-disc space-y-2 pl-6 text-neutral-700 dark:text-neutral-300">
              <li><a href="#what-ai-assisted-publishing-means-for-operations-managers-building-repeatable-pipelines">What AI-assisted publishing means for operations managers building repeatable pipelines</a></li>
              <li><a href="#what-this-site-covers">What this site covers</a></li>
              <li><a href="#main-framework-and-checklist">Main framework and checklist</a></li>
              <li><a href="#key-subtopics">Key subtopics</a></li>
              <li><a href="#faq">FAQ</a></li>
              <li><a href="#methodology-and-trust">Methodology and trust</a></li>
            </ul>
          </nav>
          <div class="grid gap-8">
            <section class="space-y-3">
              <h2 id="what-ai-assisted-publishing-means-for-operations-managers-building-repeatable-pipelines" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">What AI-assisted publishing means for operations managers building repeatable pipelines</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
            <section class="space-y-3">
              <h2 id="what-this-site-covers" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">What this site covers</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
            <section class="space-y-3">
              <h2 id="main-framework-and-checklist" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Main framework and checklist</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
            <section class="space-y-3">
              <h2 id="key-subtopics" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Key subtopics</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
            <section class="space-y-3">
              <h2 id="faq" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">FAQ</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
            <section class="space-y-3">
              <h2 id="methodology-and-trust" class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Methodology and trust</h2>
              <p class="text-neutral-700 dark:text-neutral-300">Draft pending.</p>

            </section>
          </div>
          <section class="space-y-3">
            <h2 class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Related links</h2>
            <ul class="list-disc space-y-2 pl-6 text-neutral-700 dark:text-neutral-300">
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-workflow">AI-assisted Publishing Workflow</a></li>
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-best-practices">AI-assisted Publishing Best Practices</a></li>
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-faq">AI-assisted Publishing FAQ</a></li>
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-glossary">AI-assisted Publishing Glossary</a></li>
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-checklist">AI-assisted Publishing Checklist</a></li>
              <li><a href="https://protonbraulio.github.io/lt-20260603-210708611-basic-blog-01-8611-3c75d2f4/projects/ai-assisted-publishing-methodology">AI-assisted Publishing Methodology</a></li>
            </ul>
          </section>
          <div class="rounded border p-6 border-neutral-200 dark:border-neutral-700">
            <h2 class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Next step</h2>
            <p class="mt-3 text-neutral-700 dark:text-neutral-300">Talk to Basic Blog Load Test 01 20260603-210708611 about AI-assisted publishing.</p>
          </div>
        </section>
        {
            hasContent ? (
                <>
                    {featured.length > 0 && (
                        <FeaturedContent items={featured} />
                    )}

                    {latestPosts.length > 0 && (
                        <ContentGrid
                            title="Latest Posts"
                            href="/blog"
                            viewAllText="View all posts →"
                            items={latestPosts}
                        />
                    )}

                    {latestProjects.length > 0 && (
                        <ContentGrid
                            title="Latest Projects"
                            href="/projects"
                            viewAllText="View all projects →"
                            items={latestProjects}
                            class="grid grid-cols-1 gap-8 md:grid-cols-2"
                        />
                    )}
                </>
            ) : (
                <EmptyState
                    title="Nothing here yet..."
                    message="Check back soon for new items!"
                />
            )
        }
    </Container>
</BaseLayout>
